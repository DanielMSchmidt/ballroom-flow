{
  "name": "web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit -p tsconfig.json && vite build",
    "preview": "vite preview",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "coverage": "vitest run --passWithNoTests --coverage",
    "test:e2e": "playwright test",
    "test:e2e:smoke": "playwright test --grep @smoke",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@automerge/automerge": "^3.2.6",
    "@ballroom/contract": "workspace:*",
    "@ballroom/domain": "workspace:*",
    "@clerk/clerk-react": "^5.61.3",
    "@fontsource/caveat": "^5.2.8",
    "@fontsource/inconsolata": "^5.2.8",
    "@tanstack/react-query": "^5.101.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@playwright/test": "^1.50.1",
    "@tailwindcss/vite": "^4.3.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.10.5",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/coverage-istanbul": "^3.2.6",
    "axe-core": "^4.10.2",
    "jsdom": "^26.0.0",
    "tailwindcss": "^4.3.1",
    "vite": "^6.4.3",
    "vite-plugin-pwa": "^1.3.0",
    "vite-plugin-top-level-await": "^1.6.0",
    "vite-plugin-wasm": "^3.6.0",
    "vitest": "^3.2.6",
    "vitest-axe": "^0.1.0"
  }
}
