{
  "name": "ballroom-flow",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "pnpm -r build",
    "dev": "concurrently --names web,worker --prefix-colors cyan,magenta \"pnpm --filter web dev\" \"pnpm --filter worker dev\"",
    "test": "pnpm -r test",
    "test:e2e": "pnpm --filter web test:e2e",
    "test:e2e:smoke": "pnpm --filter web test:e2e:smoke",
    "coverage": "pnpm -r coverage",
    "lint": "biome check .",
    "format": "biome format --write .",
    "typecheck": "pnpm -r typecheck",
    "prepare": "lefthook install"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.1",
    "concurrently": "^9.1.2",
    "lefthook": "^1.10.10",
    "typescript": "^6.0.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lefthook",
      "workerd",
      "@cloudflare/workerd-darwin-64",
      "@cloudflare/workerd-darwin-arm64",
      "wrangler"
    ]
  }
}
